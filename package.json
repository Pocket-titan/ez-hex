  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server:start": "nodemon --exec babel-node --extensions \".ts\" ./src/server.ts",
    "server:type-check": "tsc --noEmit",
    "server:type-check:watch": "npm run type-check -- --watch",
    "server:build": "npm run build:types && npm run build:js",
    "server:build:types": "tsc --emitDeclarationOnly",
    "server:build:js": "babel src --out-dir lib --extensions \".ts,.tsx\" --source-maps inline"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/react": "^16.9.46",
    "@types/react-dom": "^16.9.8",
    "@types/socket.io-client": "^1.4.33",
    "@babel/cli": "^7.8.3",
    "@babel/core": "^7.11.1",
    "@babel/node": "^7.10.5",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/preset-env": "^7.11.0",
    "@babel/preset-typescript": "^7.10.4",
    "nodemon": "^2.0.4"
  }
}
